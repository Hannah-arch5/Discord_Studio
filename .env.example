PORT=3000
HOST=127.0.0.1

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=replace_with_permanent_or_temp_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_API_VERSION=v24.0
WHATSAPP_VERIFY_TOKEN=choose_a_random_webhook_verify_token

# Optional but recommended. Used to validate X-Hub-Signature-256.
META_APP_SECRET=

# Your own WhatsApp number, including country code, no plus sign.
# Example: 8613800138000
ADMIN_WHATSAPP_NUMBER=

# Approved WhatsApp message template for business-initiated messages.
WHATSAPP_TEMPLATE_NAME=codex_update
WHATSAPP_TEMPLATE_LANGUAGE=zh_CN

# Telegram Bot API
# Create this with @BotFather, then send /start to your bot.
TELEGRAM_BOT_TOKEN=

# Optional. If set, only this chat can use the bot.
# The server logs your chat id when you send /start.
TELEGRAM_ADMIN_CHAT_ID=

# Discord AI Studio
# Create a bot in Discord Developer Portal, enable Message Content Intent, invite it to your server.
DISCORD_STUDIO_ENABLED=false
DISCORD_BOT_TOKEN=

# Optional. Comma-separated Discord user ids allowed to use the studio bot.
DISCORD_ALLOWED_USER_IDS=

# If true/default, Discord task progress is also mirrored to TELEGRAM_ADMIN_CHAT_ID.
DISCORD_MIRROR_TO_TELEGRAM=true

# Automatic task worker. Set to true to let the background service run Codex for new Telegram tasks.
AUTO_CODEX_ENABLED=false
CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
AUTO_CODEX_WORKDIR=/Users/hannah/Documents/Codex/2026-05-22/whatsapp
AUTO_CODEX_TIMEOUT_MS=1200000
